{
  "name": "makinosp",
  "displayName": "AIDLC-VIEWER",
  "description": "Watch AIDLC workflow folders, track stage files, and edit Markdown in a custom viewer.",
  "version": "0.0.1",
  "publisher": "makinosp",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/jikang-jeong/aidlc-viewer-extension.git"
  },
  "homepage": "https://github.com/jikang-jeong/aidlc-viewer-extension",
  "bugs": {
    "url": "https://github.com/jikang-jeong/aidlc-viewer-extension/issues"
  },
  "icon": "media/marketplace-icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "aidlc",
    "ai-dlc",
    "workflow",
    "markdown",
    "viewer",
    "sdlc"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:markdownWatchViewer.selectFolder",
    "onView:markdownWatchViewer.tree"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownWatchViewer.selectFolder",
        "title": "AIDLC-VIEWER: Select Folder",
        "shortTitle": "Open"
      },
      {
        "command": "markdownWatchViewer.refresh",
        "title": "AIDLC-VIEWER: Refresh",
        "shortTitle": "Refresh"
      },
      {
        "command": "markdownWatchViewer.openFile",
        "title": "AIDLC-VIEWER: Open File"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "markdownWatchViewer",
          "title": "AIDLC",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "markdownWatchViewer": [
        {
          "id": "markdownWatchViewer.tree",
          "name": "VIEWER"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "markdownWatchViewer.selectFolder",
          "when": "view == markdownWatchViewer.tree",
          "group": "navigation@1"
        },
        {
          "command": "markdownWatchViewer.refresh",
          "when": "view == markdownWatchViewer.tree",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "markdownWatchViewer.openFile",
          "when": "view == markdownWatchViewer.tree && viewItem == markdownFile",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "package": "vsce package",
    "compile": "node scripts/build.ts",
    "watch": "node scripts/build.ts --watch",
    "lint": "oxlint src",
    "test": "poku"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/vscode": "^1.120.0",
    "esbuild": "^0.28.1",
    "oxc": "^1.0.1",
    "poku": "^4.4.0",
    "typescript": "^6.0.3"
  }
}
